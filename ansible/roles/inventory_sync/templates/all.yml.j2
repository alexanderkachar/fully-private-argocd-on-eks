---
# Generated by ansible/roles/inventory_sync. Do not edit by hand.

aws_region: {{ tf.region | default('us-east-1') }}

{% if tf | length > 0 %}
# Verbatim terraform outputs from the infra layer.
terraform_infra:
{% for k, v in tf.items() %}
  {{ k }}: {{ v | to_json }}
{% endfor %}
{% else %}
# infra terraform state not initialised yet; outputs will appear after first apply.
terraform_infra: {}
{% endif %}

# Convenience aliases used by roles
ecr_registry_url: {{ tf.ecr_registry_url | default('') | to_json }}
cluster_name: {{ tf.cluster_name | default('') | to_json }}
gitea_hostname: {{ tf.gitea_hostname | default('') | to_json }}
argocd_hostname: {{ tf.argocd_hostname | default('') | to_json }}
grafana_hostname: {{ tf.grafana_hostname | default('') | to_json }}
gitea_server_instance_id: {{ tf.gitea_server_instance_id | default('') | to_json }}
gitea_backup_bucket: {{ tf.gitea_backup_bucket | default('') | to_json }}
gitea_admin_api_token_ssm_name: {{ tf.gitea_admin_api_token_ssm_name | default('') | to_json }}
gitea_runner_token_ssm_name: {{ tf.gitea_runner_token_ssm_name | default('') | to_json }}
gitea_runner_ready_ssm_name: {{ tf.gitea_runner_ready_ssm_name | default('') | to_json }}
vpn_endpoint_id: {{ tf.vpn_endpoint_id | default('') | to_json }}
