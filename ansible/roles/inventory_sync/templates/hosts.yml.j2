---
# Generated by ansible/roles/inventory_sync. Do not edit by hand.
# Re-render with `ansible-playbook -t inventory_sync <any-playbook>` or just by running the playbook.

all:
  hosts:
    localhost:
      ansible_connection: local
      ansible_python_interpreter: "{{ '{{' }} ansible_playbook_python {{ '}}' }}"
{% if tf.gitea_server_instance_id is defined %}
  children:
    gitea_servers:
      hosts:
        gitea:
          ansible_host: {{ tf.gitea_server_instance_id }}
          ansible_connection: community.aws.aws_ssm
          ansible_aws_ssm_region: {{ tf.region | default('us-east-1') }}
          ansible_aws_ssm_bucket_name: {{ tf.gitea_config_bucket | default('') }}
{% if tf.gitea_runner_instance_id is defined %}
    gitea_runners:
      hosts:
        gitea-runner:
          ansible_host: {{ tf.gitea_runner_instance_id }}
          ansible_connection: community.aws.aws_ssm
          ansible_aws_ssm_region: {{ tf.region | default('us-east-1') }}
          ansible_aws_ssm_bucket_name: {{ tf.gitea_config_bucket | default('') }}
{% endif %}
{% endif %}
